# Production server environment
# Copy to server/.env on your API host and replace placeholder values.

NODE_ENV=production
PORT=3001

# MySQL — use your host's managed database or VPS MySQL instance
DATABASE_URL="mysql://USER:PASSWORD@db-host.example.com:3306/van_conversion"

# Auth — generate a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=24h

# Public API URL (used for uploaded image links when not using Cloudinary)
API_BASE_URL=https://api.yourdomain.com

# Comma-separated origins for the public site and admin dashboard
CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com

# Google reCAPTCHA v3 — secret key (required in production)
RECAPTCHA_SECRET_KEY=

# Email notifications for new inquiries
ADMIN_EMAIL=hello@yourdomain.com
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Media uploads — strongly recommended for production
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Newsletter integrations (optional — pick one or leave blank)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=
BUTTONDOWN_API_KEY=

# Public brochure PDF path (served from client static build)
BROCHURE_URL=/brochure/van-conversion-brochure.pdf

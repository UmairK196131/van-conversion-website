{
  "name": "van-conversion-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Van Conversion & Camper Website — monorepo",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "client",
    "admin",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev -w client\" \"npm run dev -w server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run db:generate -w server && npm run lint && npm run format:check && npm run typecheck && npm run build -w client",
    "typecheck": "npm run typecheck -w server",
    "db:generate": "npm run db:generate -w server",
    "db:migrate": "npm run db:migrate -w server",
    "db:seed": "npm run db:seed -w server",
    "db:studio": "npm run db:studio -w server",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3"
  }
}

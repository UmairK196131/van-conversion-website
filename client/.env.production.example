# Production client environment
# Set these in your static host's dashboard (Vercel, Netlify, etc.) before building.

# Public website URL — no trailing slash
VITE_SITE_URL=https://yourdomain.com

# Google reCAPTCHA v3 — site key (pair with RECAPTCHA_SECRET_KEY on server)
VITE_RECAPTCHA_SITE_KEY=

# Optional widgets and integrations
VITE_WHATSAPP_NUMBER=15551234567
VITE_CALENDLY_URL=https://calendly.com/your-account/consultation
VITE_TAWK_PROPERTY_ID=
VITE_TAWK_WIDGET_ID=
VITE_PANORAMA_URL=

# Used at build time only — API URL for sitemap generation (CI/build step)
SITEMAP_API_URL=https://api.yourdomain.com/api
